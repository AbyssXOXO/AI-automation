GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

TELEGRAM_BOT_TOKEN=123456:telegram-bot-token
TELEGRAM_CHAT_ID=123456789
# Optional alias if you prefer this env name:
# TELEGRAM_ACCOUNT_ID=123456789

TARGET_COMPANIES=Google, Microsoft, IBM
USER_PROFILE=Student interested in Python, AI, cloud, free courses, hackathons, and developer opportunities.

TOPIC_PROMPT=Free courses, hackathons, coding challenges, student programs, developer events, certification offers, and hands-on AI or cloud opportunities from Google, Microsoft, and IBM.
RELEVANCE_THRESHOLD=0.7
SCAN_INTERVAL_MINUTES=180
MAX_ITEMS_PER_SCAN=25
MAX_ITEMS_PER_SOURCE=8
#In your config.py, the MAX_TEXT_CHARS defaults to 5000. This means the bot only reads roughly the first ~800 words of the page.
MAX_TEXT_CHARS=10000

# Optional RSS sources. The bot already has default scrape targets for Google,
# Microsoft, and IBM, so this can stay empty.
RSS_FEEDS=

# Optional override. If omitted, the bot uses curated default scrape targets:
# Google for Developers Events, Google Cloud Skills Boost Paths,
# Google Developers Codelabs, Microsoft Learn Student Hub,
# Microsoft Learn Hack Together, Microsoft Credentials AI Challenge,
# Microsoft Student Credentials, IBM SkillsBuild, IBM SkillsBuild Course Catalog,
# and IBM Free Digital Learning.
#
# SCRAPE_TARGETS=[
#   {"name":"Custom Source","url":"https://example.com","company":"Google","category":"hackathons","limit":6}
# ]

# Render/Cron-job.org friendly behavior.
RUN_BACKGROUND_LOOP=true
RUN_SCAN_ON_STARTUP=false
